{
    "name": "callmeleon167/debugphp-server",
    "description": "Self-hosted server for DebugPHP — real-time PHP debugging dashboard.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "debug",
        "debugging",
        "php",
        "real-time",
        "sse",
        "dashboard"
    ],
    "homepage": "https://debugphp.dev",
    "authors": [
        {
            "name": "Leon Schmidt",
            "homepage": "https://github.com/CallMeLeon167",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/CallMeLeon167/debugphp-server/issues",
        "source": "https://github.com/CallMeLeon167/debugphp-server"
    },
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "DebugPHP\\Server\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "stable"
}
